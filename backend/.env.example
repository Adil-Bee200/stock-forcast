# Copy to backend/.env and adjust values.
# Optional override: backend/.env.local (gitignored)

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
API_TITLE=Stock Predictor API
API_VERSION=1.0.0
# Dev: * allows any origin. Production: set to your Netlify URL only (see below).
CORS_ORIGINS=*
# Production fallback when CORS_ORIGINS is * or empty (Render: set this env var).
# FRONTEND_URL=https://your-app.netlify.app

# --- Database (use DATABASE_URL on hosted Postgres, or discrete vars locally) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stock_predictor
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/stock_predictor

DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
# true = create_all on API start (dev only); false = use Alembic migrations
DB_AUTO_CREATE=false

# --- Worker (EOD ingest + nightly Prophet / naive baseline) ---
WORKER_SYMBOLS=AAPL,MSFT,AMZN,GOOGL,META,NVDA,TSLA
WORKER_TIMEZONE=America/New_York
WORKER_DAILY_HOUR=22
WORKER_DAILY_MINUTE=5
WORKER_INGEST_PERIOD=1y
WORKER_FETCH_TICKER_INFO=true
WORKER_TRAIN_MIN_ROWS=60
WORKER_RUN_ON_START=false

# --- Live intraday (Twelve Data — 5min candles for 1D chart) ---
MARKET_DATA_PROVIDER=your_twelve_data_api_key
# MARKET_DATA_API_KEY=your_twelve_data_api_key
INTRADAY_CACHE_TTL_SECONDS=300
